#!/usr/bin/env bash
#
# pre-push: intercept pushes and deploy to gh-pages.
#
# Enable once (after `git init` + adding a remote):
#     git config core.hooksPath .githooks
#
# Requires git >= 2.23 (for `git switch`).
set -euo pipefail

REMOTE="origin"
DEPLOY_BRANCH="gh-pages"

# --- recursion guard --------------------------------------------------------
# The deploy script runs `git push`, which re-triggers this hook. Bail.
[ "${YANTRALOK_DEPLOYING:-}" = "1" ] && exit 0

# --- decide whether this push should deploy ---------------------------------
# Deploys on every branch push except gh-pages itself. To limit to main only,
# change the `refs/heads/*` line to `refs/heads/main`.
deploy=false
while read -r _local_ref _local_sha remote_ref _remote_sha; do
  case "$remote_ref" in
    "refs/heads/$DEPLOY_BRANCH") ;;   # never redeploy off the gh-pages branch
    refs/heads/*) deploy=true ;;
  esac
done
$deploy || exit 0

# --- delegate to the deploy script -------------------------------------------
REPO_ROOT="$(git rev-parse --show-toplevel)"
unset GIT_DIR GIT_WORK_TREE GIT_INDEX_FILE GIT_PREFIX
cd "$REPO_ROOT"

export YANTRALOK_DEPLOYING=1
bash ./scripts/deploy.sh
